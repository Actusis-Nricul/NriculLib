-- =====================
-- ICON FALLBACK (Lucide-name -> glyph)
-- Since this library has no hosted icon spritesheet, names map to
-- text glyphs/emoji as a lightweight fallback. Pass any string name;
-- unmapped names just render blank rather than erroring.
-- =====================
local IconGlyphs = {
    home = "⌂", settings = "⚙", gear = "⚙", user = "☺", users = "☺☺",
    play = "▶", pause = "❚❚", stop = "■", trash = "🗑", search = "🔍",
    star = "★", heart = "♥", bell = "🔔", lock = "🔒", unlock = "🔓",
    eye = "👁", zap = "⚡", flame = "🔥", skull = "☠", shield = "🛡",
    gamepad = "🎮", sword = "⚔", map = "🗺", check = "✓", x = "✕",
    arrowup = "↑", arrowdown = "↓", arrowleft = "←", arrowright = "→",
    plus = "+", minus = "-", info = "ⓘ", warning = "⚠", clock = "🕐",
    folder = "📁", file = "📄", download = "↓", upload = "↑",
    key = "🔑", chevronup = "︿", chevrondown = "﹀",
}

local function resolveIconGlyph(icon)
    if not icon or icon == "" then return "" end
    if typeof(icon) == "string" then
        local glyph = IconGlyphs[icon:lower():gsub("[%-%s]", "")]
        return glyph or ""
    end
    return ""
end

