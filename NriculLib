-- =====================
-- HELPERS
-- =====================
local function create(class, props)
    local inst = Instance.new(class)
    for k, v in pairs(props or {}) do
        if k ~= "Parent" then inst[k] = v end
    end
    if props and props.Parent then inst.Parent = props.Parent end
    return inst
end

local function tween(obj, info, props)
    local t = TweenService:Create(obj, info, props)
    t:Play()
    return t
end

local QUICK = TweenInfo.new(0.25, Enum.EasingStyle.Quint)

local function round(inst, radius)
    create("UICorner", {CornerRadius = UDim.new(0, radius or 8), Parent = inst})
end

local function stroke(inst, color, thickness)
    return create("UIStroke", {
        Color = color or SelectedTheme.ElementStroke,
        Thickness = thickness or 1,
        Parent = inst,
    })
end

local function safeCall(fn, ...)
    if not fn then return true end
    local ok, err = pcall(fn, ...)
    if not ok then
        warn("NriculLib | Callback Error: " .. tostring(err))
    end
    return ok, err
end

-- =====================
-- FILESYSTEM SAFE WRAPPERS
-- =====================
local hasFS = type(isfolder) == "function" and type(makefolder) == "function"
    and type(isfile) == "function" and type(writefile) == "function" and type(readfile) == "function"

local function ensureFolder(path)
    if hasFS then
        pcall(function()
            if not isfolder(path) then makefolder(path) end
        end)
    end
end

-- =====================
-- DISCORD JOIN HANDLING (fixed)
-- Marks a per-invite file in NriculLib/Discord Invites so the user
-- is only ever asked once per invite code, persisting across sessions
-- via the executor's own filesystem.
-- =====================
local function handleDiscordPrompt(window, discordSettings)
    if not discordSettings or not discordSettings.Enabled then return end
    if not discordSettings.Invite or discordSettings.Invite == "" then return end

    local folder = "NriculLib/Discord Invites"
    ensureFolder("NriculLib")
    ensureFolder(folder)

    local markerFile = folder .. "/" .. tostring(discordSettings.Invite) .. ".joined"

    local alreadyJoined = false
    if hasFS then
        local ok, result = pcall(isfile, markerFile)
        alreadyJoined = ok and result
    end

    if alreadyJoined and discordSettings.RememberJoins ~= false then
        return -- silently skip, already prompted
    end

    -- try native Discord RPC invite popup (works if Discord desktop app running)
    local requestFunc = (syn and syn.request) or (fluxus and fluxus.request)
        or (http and http.request) or http_request or request

    local rpcSucceeded = false
    if requestFunc then
        local ok = pcall(function()
            local res = requestFunc({
                Url = "http://127.0.0.1:6463/rpc?v=1",
                Method = "POST",
                Headers = {
                    ["Content-Type"] = "application/json",
                    Origin = "https://discord.com",
                },
                Body = HttpService:JSONEncode({
                    cmd = "INVITE_BROWSER",
                    nonce = HttpService:GenerateGUID(false),
                    args = {code = discordSettings.Invite},
                }),
            })
            if res and (res.StatusCode == 200 or res.Success) then
                rpcSucceeded = true
            end
        end)
    end

    -- regardless of RPC success, notify the user so they always have a path to join
    if window and window.Notify then
        window:Notify({
            Title = "Join our Discord",
            Content = rpcSucceeded
                and "Discord invite sent — check your Discord app!"
                or ("Join us: discord.gg/" .. tostring(discordSettings.Invite)),
            Duration = 8,
        })
    end

    if hasFS then
        pcall(function()
            writefile(markerFile, "joined at " .. tostring(os.time()))
        end)
    end
end

